---
const metrics = [
  {
    value: "+200%",
    label: "ROI Promedio Anual",
    desc: "Retorno generado por la digitalización y optimización de procesos de venta B2B."
  },
  {
    value: "99.9%",
    label: "Uptime Garantizado",
    desc: "Arquitectura de servidores redundantes para asegurar que su negocio nunca se detenga."
  },
  {
    value: "<0.8s",
    label: "Tiempo de Carga",
    desc: "Velocidad de extremo a extremo que mejora el SEO y destruye el rebote de usuarios."
  }
];
---

<section id="metricas" class="py-24 relative z-10 bg-black/80 border-b border-white/5">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-8">
      {metrics.map((m, i) => (
        <div class="flex flex-col border-l border-white/10 pl-6 fade-up" style={`transition-delay: ${i * 0.1}s`}>
          <div class="text-5xl md:text-6xl font-black text-white tracking-tighter mb-2">
            {m.value}
          </div>
          <h4 class="text-sm font-bold uppercase tracking-widest text-[#8B1A2B] mb-3">
            {m.label}
          </h4>
          <p class="text-xs text-white/50 leading-relaxed font-light max-w-xs">
            {m.desc}
          </p>
        </div>
      ))}
    </div>

  </div>
</section>
