---
const links = [
  { text: "Inicio", href: "#inicio" },
  { text: "Soluciones", href: "#servicios" },
  { text: "Casos de Estudio", href: "#proyectos" },
  { text: "Clientes", href: "#clientes" },
  { text: "Inversión", href: "#planes" },
];
---

<header class="fixed w-full top-0 z-50 transition-all duration-300 border-b border-transparent" id="navbar">
  <div class="max-w-7xl mx-auto px-6 py-5 flex justify-between items-center">
    
    <!-- Logo -->
    <a href="#" class="flex items-center gap-4 group relative z-10">
      <img src="/images/logo.png" alt="VC Logo" class="w-7 h-7 object-contain opacity-90 group-hover:opacity-100 transition-opacity" />
      <span class="font-bold tracking-widest text-white text-xs uppercase">Vision<span class="text-white/50">Code</span></span>
    </a>

    <!-- Desktop Menu -->
    <nav class="hidden md:flex items-center gap-8">
      {links.map(link => (
        <a href={link.href} class="text-[0.7rem] font-bold uppercase tracking-widest text-white/60 hover:text-white transition-colors">
          {link.text}
        </a>
      ))}
    </nav>

    <!-- Desktop CTA -->
    <div class="hidden md:block">
      <a href="#contacto" class="text-[0.7rem] font-bold uppercase tracking-widest text-white border-b border-white/30 hover:border-white pb-1 transition-all">
        Contactar Ejecutivo
      </a>
    </div>

    <!-- Mobile Menu Button -->
    <button class="md:hidden text-white/70 hover:text-white" id="mobile-btn" aria-label="Menu">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
    </button>
  </div>
</header>

<script>
  let lastScroll = 0;
  const navbar = document.getElementById('navbar');
  
  window.addEventListener('scroll', () => {
    if(!navbar) return;
    const currentScroll = window.pageYOffset;
    
    // Background and border on scroll
    if (currentScroll > 50) {
      navbar.classList.add('bg-black/70', 'backdrop-blur-md', 'border-white/10');
      navbar.classList.remove('border-transparent');
    } else {
      navbar.classList.remove('bg-black/70', 'backdrop-blur-md', 'border-white/10');
      navbar.classList.add('border-transparent');
    }

    // Hide on scroll down
    if (currentScroll > lastScroll && currentScroll > 200) {
      navbar.style.transform = 'translateY(-100%)';
    } else {
      navbar.style.transform = 'translateY(0)';
    }
    lastScroll = currentScroll;
  });
</script>
