---
const year = new Date().getFullYear();
---

<footer class="relative z-10 pt-20 pb-10 px-6 lg:px-10 border-t border-white/10 bg-black/80">
  
  <div class="max-w-7xl mx-auto flex flex-col items-center">
    
    <div class="mb-12 flex flex-col items-center">
      <img src="/images/logo.png" alt="VC Logo" class="w-8 h-8 object-contain mb-4 opacity-50 grayscale" />
      <h3 class="text-lg font-bold tracking-widest uppercase text-white/80 mb-2">VisionCode</h3>
      <p class="text-xs text-white/40 text-center max-w-sm uppercase tracking-widest">
        Ingeniería de Software & Consultoría
      </p>
    </div>

    <div class="w-full flex flex-col md:flex-row justify-between items-center gap-4 pt-8 border-t border-white/5">
      <div class="text-xs text-white/30 uppercase tracking-widest">
        &copy; {year} Vision Code. All rights reserved.
      </div>
      <div class="flex gap-6 text-xs text-white/40 uppercase tracking-widest font-bold">
        <a href="#" class="hover:text-white transition-colors">Políticas</a>
        <a href="#" class="hover:text-white transition-colors">LinkedIn</a>
      </div>
    </div>
  </div>
</footer>
