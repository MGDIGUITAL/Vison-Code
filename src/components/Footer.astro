---
const year = new Date().getFullYear();
---

<footer class="relative z-10 pt-20 pb-8 px-6 lg:px-10 overflow-hidden">
  
  <!-- Separador superior con glow central -->
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[300px] h-[300px] bg-[#8B1A2B]/20 blur-[100px] rounded-full pointer-events-none"></div>

  <div class="max-w-7xl mx-auto flex flex-col items-center">
    
    <div class="mb-12 flex flex-col items-center">
      <div class="w-12 h-12 rounded-full bg-white/5 border border-white/10 flex items-center justify-center p-2 mb-4">
         <img src="/images/logo.png" alt="VC Logo" class="w-full h-full object-contain" />
      </div>
      <h3 class="text-2xl font-bold tracking-tight text-white mb-2">VisionCode</h3>
      <p class="text-sm text-white/50 text-center max-w-sm">
        Arquitectura digital y tecnología enfocada en resultados escalables.
      </p>
    </div>

    <!-- Navegación Footer -->
    <div class="flex flex-wrap justify-center gap-6 md:gap-10 text-sm font-semibold text-white/60 mb-12">
      <a href="#inicio" class="hover:text-white transition-colors">Inicio</a>
      <a href="#servicios" class="hover:text-white transition-colors">Soluciones</a>
      <a href="#proyectos" class="hover:text-white transition-colors">Casos de Éxito</a>
      <a href="#planes" class="hover:text-white transition-colors">Planes</a>
    </div>

    <div class="w-full flex flex-col md:flex-row justify-between items-center gap-4 pt-8 border-t border-white/5">
      <div class="text-xs text-white/40">
        &copy; {year} Vision Code. All rights reserved.
      </div>
      <div class="flex gap-4">
        <a href="#" class="w-8 h-8 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-white/40 hover:text-white hover:bg-white/10 transition-all" aria-label="Instagram">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
        </a>
        <a href="#" class="w-8 h-8 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-white/40 hover:text-white hover:bg-white/10 transition-all" aria-label="LinkedIn">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
        </a>
      </div>
    </div>
  </div>
</footer>
