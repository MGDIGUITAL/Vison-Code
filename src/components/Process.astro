---
const steps = [
  { num: "01", title: "Consultoría Estratégica", desc: "Auditoría técnica y definición de la arquitectura comercial." },
  { num: "02", title: "Prototipado", desc: "Diseño de interfaces bajo estándares UX/UI corporativos." },
  { num: "03", title: "Ingeniería de Software", desc: "Desarrollo del código fuente con actualizaciones semanales." },
  { num: "04", title: "Quality Assurance", desc: "Auditoría de seguridad, rendimiento y estrés de servidores." },
  { num: "05", title: "Despliegue a Producción", desc: "Lanzamiento oficial y capacitación técnica al equipo interno." },
];
---

<section id="proceso" class="py-32 relative z-10 border-t border-white/5">
  <div class="max-w-6xl mx-auto px-6 lg:px-10">
    
    <div class="flex flex-col md:flex-row justify-between items-end gap-6 mb-24 fade-up">
      <div>
        <div class="saas-badge mb-4">Metodología de Trabajo</div>
        <h2 class="text-4xl md:text-5xl font-bold tracking-tight text-white">
          Fases de <span class="text-white/40">Ingeniería.</span>
        </h2>
      </div>
    </div>

    <!-- Corporate Timeline -->
    <div class="grid grid-cols-1 md:grid-cols-5 gap-8">
      {steps.map((step, i) => (
        <div class="flex flex-col fade-up relative" style={`transition-delay: ${i * 0.1}s`}>
          <!-- Línea conectora (oculta en el último) -->
          {i !== steps.length - 1 && (
            <div class="hidden md:block absolute top-6 left-12 right-[-2rem] h-px bg-white/10"></div>
          )}
          
          <div class="w-12 h-12 rounded border border-white/20 bg-black/50 backdrop-blur-md flex items-center justify-center font-bold text-lg text-white mb-6 relative z-10">
             {step.num}
          </div>

          <h3 class="text-lg font-bold text-white mb-3 pr-4">{step.title}</h3>
          <p class="text-sm text-white/50 leading-relaxed font-light pr-4">{step.desc}</p>
        </div>
      ))}
    </div>

  </div>
</section>
