---
const steps = [
  { num: "01", title: "Reunión Inicial", desc: "Conversamos sobre tu negocio y definimos objetivos comerciales." },
  { num: "02", title: "Análisis & Arquitectura", desc: "Diseñamos la estructura de datos y el flujo de la plataforma." },
  { num: "03", title: "Propuesta Técnica", desc: "Validamos el alcance, tecnologías y tiempos de entrega." },
  { num: "04", title: "Desarrollo Activo", desc: "Construcción de la plataforma con actualizaciones en tiempo real." },
  { num: "05", title: "Testing & QA", desc: "Pruebas de rendimiento, seguridad y responsividad multiplataforma." },
  { num: "06", title: "Lanzamiento", desc: "Despliegue a producción y capacitación de tu equipo." },
];
---

<section id="proceso" class="py-24 relative z-10">
  <div class="max-w-4xl mx-auto px-6 lg:px-10">
    
    <div class="text-center mb-20 fade-up">
      <div class="saas-badge mb-4 mx-auto">Workflow</div>
      <h2 class="text-4xl md:text-5xl font-bold tracking-tight text-white mb-4">
        Proceso de <br/><span class="text-white/40">despliegue.</span>
      </h2>
    </div>

    <!-- Timeline estilo Workflow SaaS -->
    <div class="relative">
      <!-- Línea central brillante -->
      <div class="absolute left-[27px] md:left-1/2 top-4 bottom-4 w-px bg-gradient-to-b from-transparent via-[#8B1A2B]/50 to-transparent md:-translate-x-1/2"></div>
      
      <div class="space-y-12 relative z-10">
        {steps.map((step, i) => (
          <div class={`flex flex-col md:flex-row items-start md:items-center justify-between gap-6 md:gap-12 fade-up ${i % 2 === 0 ? 'md:flex-row-reverse' : ''}`} style={`transition-delay: ${i * 0.1}s`}>
            
            <!-- Espacio vacío para alternar -->
            <div class="hidden md:block w-full md:w-1/2"></div>

            <!-- Nodo / Botón Central -->
            <div class="absolute left-0 md:left-1/2 md:-translate-x-1/2 w-14 h-14 rounded-full bg-[var(--saas-bg)] border-4 border-[var(--saas-bg)] flex items-center justify-center z-10 shadow-[0_0_20px_rgba(139,26,43,0.15)] group">
               <div class="w-full h-full rounded-full bg-white/5 border border-white/10 flex items-center justify-center font-bold text-xs text-[#8B1A2B] group-hover:bg-[#8B1A2B] group-hover:text-white transition-colors">
                 {step.num}
               </div>
            </div>

            <!-- Contenido del paso -->
            <div class="w-full md:w-1/2 pl-20 md:pl-0 bento-card p-6">
              <h3 class="text-lg font-bold text-white mb-2">{step.title}</h3>
              <p class="text-sm text-white/60 leading-relaxed">{step.desc}</p>
            </div>
            
          </div>
        ))}
      </div>
    </div>

  </div>
</section>
