---
---
<section id="inicio" class="relative w-full h-screen min-h-[600px] flex items-center justify-center overflow-hidden">
  
  <!-- Video de Fondo Full-Screen -->
  <div class="absolute inset-0 w-full h-full z-0">
    <video 
      src="/videos/HERO.mp4" 
      autoplay 
      loop 
      muted 
      playsinline 
      class="w-full h-full object-cover scale-105"
    ></video>
    
    <!-- Overlays Cinemáticos -->
    <div class="absolute inset-0 bg-black/60"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-[var(--saas-bg)] via-transparent to-black/40"></div>
  </div>

  <!-- Contenido Central -->
  <div class="relative z-10 max-w-5xl mx-auto px-6 lg:px-10 flex flex-col items-center text-center mt-20 fade-up">
    
    <div class="saas-badge mb-8 border-white/30 text-white tracking-widest backdrop-blur-md bg-white/5">
      Firma de Ingeniería de Software
    </div>

    <h1 class="text-5xl md:text-7xl lg:text-8xl font-bold tracking-tighter text-white leading-[1.05] mb-8 drop-shadow-2xl">
      Infraestructura digital<br/>
      para <span class="text-transparent bg-clip-text bg-gradient-to-b from-white to-white/60">líderes.</span>
    </h1>

    <p class="text-lg md:text-xl text-white/80 max-w-3xl mx-auto leading-relaxed mb-12 font-light">
      Desarrollamos ecosistemas tecnológicos corporativos, e-commerce de alto rendimiento y sistemas de gestión avanzados para empresas que no toleran plantillas.
    </p>

    <div class="flex flex-col sm:flex-row gap-6 w-full sm:w-auto">
      <a href="#contacto" class="btn-primary w-full sm:w-auto text-sm tracking-wide">
        Agendar Consultoría
      </a>
      <a href="#servicios" class="btn-secondary w-full sm:w-auto text-sm tracking-wide bg-transparent border-white/30 backdrop-blur-md">
        Explorar Soluciones
      </a>
    </div>
  </div>

  <!-- Scroll Down Indicator -->
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-2 opacity-50 fade-up" style="transition-delay: 0.5s">
    <span class="text-[0.6rem] uppercase tracking-widest text-white font-bold">Descubrir</span>
    <div class="w-px h-12 bg-gradient-to-b from-white to-transparent"></div>
  </div>

</section>
