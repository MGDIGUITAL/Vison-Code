---
const plans = [
  {
    name: "Landing Básica",
    price: "$58.000",
    usd: "$60 USD",
    monthly: "$10.000 CLP/mes",
    popular: false,
    features: [
      "1 página landing profesional",
      "Hosting + dominio (1 año)",
      "Logo creado con IA",
      "Imágenes optimizadas con IA",
      "Soporte técnico 30 días",
      "Diseño responsive",
      "Formulario de contacto",
    ],
    cta: "Empezar ahora",
  },
  {
    name: "Landing + Sitio Web",
    price: "$80.000",
    usd: "$83 USD",
    monthly: "$15.000 CLP/mes",
    popular: true,
    badge: "Más popular",
    features: [
      "Landing + 6 páginas internas",
      "Hosting + dominio (1 año)",
      "Logo creado con IA",
      "Imágenes optimizadas con IA",
      "Soporte técnico 30 días",
      "Diseño responsive",
      "Blog o sección de noticias",
      "Google Analytics",
    ],
    cta: "Elegir este plan",
  },
  {
    name: "Landing + E-Commerce",
    price: "$150.000",
    usd: "$156 USD",
    monthly: "$20.000 CLP/mes",
    popular: false,
    features: [
      "Landing + tienda online",
      "Hosting + dominio (1 año)",
      "Logo + imágenes con IA",
      "Soporte técnico 30 días",
      "Carrito de compras",
      "Mercado Pago / Webpay",
      "Panel de administración",
      "Hasta 50 productos",
    ],
    cta: "Empezar ahora",
  },
  {
    name: "E-Commerce + ERP",
    price: "$300.000",
    usd: "$312 USD",
    monthly: "$30.000 CLP/mes",
    popular: false,
    badge: "Más completo",
    features: [
      "Todo lo del plan E-Commerce",
      "Sistema ERP / CRM interno",
      "Gestión de inventario y ventas",
      "Panel de clientes y proveedores",
      "Reportes y estadísticas",
      "Roles y permisos de usuarios",
      "Soporte técnico 60 días",
      "Capacitación incluida",
    ],
    cta: "Contactar",
  },
];

const extras = [
  { name: "Sitio en 2 idiomas", price: "desde $38.000" },
  { name: "SEO avanzado", price: "desde $48.000" },
  { name: "Integración redes sociales", price: "desde $24.000" },
  { name: "Email corporativo (5 cuentas)", price: "desde $29.000" },
  { name: "Sesión de fotos con IA", price: "desde $34.000" },
  { name: "Dashboard de métricas", price: "desde $58.000" },
  { name: "Más de 50 productos", price: "desde $29.000" },
];
---

<section id="planes" class="py-28 bg-[#111111] relative">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">
    <!-- Section header -->
    <div class="text-center mb-16 reveal">
      <span class="accent-line mx-auto block"></span>
      <h2 class="font-display text-4xl md:text-5xl font-bold text-white mb-4">
        Planes y <span class="text-brand-red">precios</span>
      </h2>
      <p class="font-body text-white/60 text-lg max-w-xl mx-auto">
        Inversión única, sin sorpresas. Todos los planes incluyen hosting y dominio por 1 año.
      </p>
    </div>

    <!-- Plans grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-4 mb-20">
      {plans.map((plan, i) => (
        <div class={`pricing-card reveal reveal-delay-${i + 1} ${plan.popular ? 'pricing-featured' : ''}`}>
          {plan.badge && (
            <div class={`plan-badge ${plan.popular ? 'badge-popular' : 'badge-complete'}`}>
              {plan.badge}
            </div>
          )}
          <div class="p-8">
            <h3 class="font-display text-lg font-semibold text-white mb-1">{plan.name}</h3>
            <div class="mt-4 mb-1">
              <span class="font-display text-3xl font-bold text-white">{plan.price}</span>
              <span class="font-body text-white/40 text-sm ml-1">CLP</span>
            </div>
            <div class="font-body text-brand-red text-sm mb-1">{plan.usd}</div>
            <div class="font-body text-white/35 text-xs mb-6">Mantenimiento: {plan.monthly}</div>

            <ul class="space-y-3 mb-8">
              {plan.features.map(f => (
                <li class="flex items-start gap-3">
                  <svg class="flex-shrink-0 mt-0.5" width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <path d="M3 8l3.5 3.5L13 4" stroke="#8B1A2B" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  <span class="font-body text-sm text-white/65">{f}</span>
                </li>
              ))}
            </ul>

            <a 
              href="#contacto" 
              class={`block text-center font-body font-semibold text-sm py-3 px-4 tracking-wide transition-all duration-200 ${plan.popular ? 'bg-brand-red hover:bg-brand-red-light text-white' : 'border border-white/20 hover:border-brand-red text-white hover:bg-brand-red/10'}`}
            >
              {plan.cta}
            </a>
          </div>
        </div>
      ))}
    </div>

    <!-- Extras section -->
    <div class="reveal">
      <div class="border border-white/10 p-8 md:p-10">
        <h3 class="font-display text-2xl font-semibold text-white mb-2">Servicios adicionales</h3>
        <p class="font-body text-white/50 text-sm mb-8">Opcionales y negociables. Se acuerdan antes de iniciar el proyecto.</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {extras.map(e => (
            <div class="extra-item flex justify-between items-center py-3 border-b border-white/8">
              <span class="font-body text-sm text-white/70">{e.name}</span>
              <span class="font-body text-sm font-semibold text-brand-red">{e.price}</span>
            </div>
          ))}
        </div>
        <p class="font-body text-xs text-white/30 mt-6">* Todos los precios en CLP. Los valores en USD son referenciales.</p>
      </div>
    </div>
  </div>
</section>

<style>
  .pricing-card {
    background: #1a1a1a;
    border: 1px solid rgba(255,255,255,0.08);
    position: relative;
    transition: border-color 0.3s;
  }
  .pricing-card:hover {
    border-color: rgba(139, 26, 43, 0.4);
  }
  .pricing-featured {
    border-color: #8B1A2B !important;
    background: #1e1010;
  }
  .plan-badge {
    font-family: 'Inter', sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.35rem 1rem;
    text-align: center;
  }
  .badge-popular {
    background: #8B1A2B;
    color: white;
  }
  .badge-complete {
    background: #2d2d2d;
    color: rgba(255,255,255,0.6);
  }
  .extra-item:last-child { border-bottom: none; }
  .border-white\/8 { border-color: rgba(255,255,255,0.08); }
</style>
