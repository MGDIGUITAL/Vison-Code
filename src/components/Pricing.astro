---
const plans = [
  {
    name: "Landing Básica",
    price: "$58.000",
    usd: "$60 USD",
    monthly: "$10.000 CLP/mes",
    popular: false,
    features: [
      "1 página landing",
      "Hosting + dominio (1 año)",
      "Logo creado con IA",
      "Imágenes optimizadas",
      "Soporte 30 días",
      "Formulario contacto",
    ],
  },
  {
    name: "Landing + Sitio Web",
    price: "$80.000",
    usd: "$83 USD",
    monthly: "$15.000 CLP/mes",
    popular: true,
    features: [
      "Landing + 6 páginas",
      "Hosting + dominio (1 año)",
      "Logo creado con IA",
      "Google Analytics",
      "Soporte 30 días",
      "Blog/Noticias",
    ],
  },
  {
    name: "E-Commerce",
    price: "$150.000",
    usd: "$156 USD",
    monthly: "$20.000 CLP/mes",
    popular: false,
    features: [
      "Tienda online completa",
      "Hosting + dominio (1 año)",
      "Panel de administración",
      "Mercado Pago / Webpay",
      "Soporte 30 días",
      "Hasta 50 productos",
    ],
  },
  {
    name: "E-Commerce + ERP",
    price: "$300.000",
    usd: "$312 USD",
    monthly: "$30.000 CLP/mes",
    popular: false,
    features: [
      "Suite E-commerce total",
      "Sistema ERP interno",
      "Gestión de inventario",
      "Reportes de ventas",
      "Roles de usuario",
      "Capacitación",
    ],
  },
];

const extras = [
  { name: "Sitio bilingüe", price: "desde $38.000" },
  { name: "SEO Técnico", price: "desde $48.000" },
  { name: "Email corporativo (5)", price: "desde $29.000" },
  { name: "Dashboard Métricas", price: "desde $58.000" },
];
---

<section id="planes" class="py-24 relative z-10">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">
    
    <div class="text-center mb-20 fade-up">
      <div class="saas-badge mb-4 mx-auto">Planes Comerciales</div>
      <h2 class="text-4xl md:text-5xl font-bold tracking-tight text-white mb-4">
        Inversión <span class="text-white/40">transparente.</span>
      </h2>
      <p class="text-sm text-white/50 max-w-lg mx-auto">Pago único por desarrollo. Todos los planes incluyen hosting, dominio y SSL por el primer año.</p>
    </div>

    <!-- Grid Pricing -->
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6 mb-16">
      {plans.map((plan, i) => (
        <div class={`bento-card flex flex-col relative fade-up ${plan.popular ? 'border-[#8B1A2B]/40 shadow-[0_0_30px_rgba(139,26,43,0.1)]' : ''}`} style={`transition-delay: ${i * 0.1}s`}>
          
          {plan.popular && (
             <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-[#8B1A2B] to-transparent"></div>
          )}

          <div class="p-8 flex flex-col h-full relative z-10">
            {plan.popular && (
              <div class="saas-badge self-start bg-[#8B1A2B]/20 border-[#8B1A2B]/40 text-[#8B1A2B] mb-4 text-[0.65rem]">
                Recomendado
              </div>
            )}
            
            <h3 class="text-xl font-bold text-white mb-2">{plan.name}</h3>
            
            <div class="mb-6 pb-6 border-b border-white/5">
              <div class="flex items-baseline gap-1 mb-1">
                <span class="text-3xl font-bold text-white tracking-tight">{plan.price}</span>
                <span class="text-xs font-semibold text-white/40">CLP</span>
              </div>
              <div class="text-xs text-white/30 mb-2">Ref: {plan.usd}</div>
              <div class="text-[0.65rem] text-white/40 bg-white/5 inline-block px-2 py-1 rounded">
                Mantenimiento anual: <span class="text-white/70">{plan.monthly}</span>
              </div>
            </div>

            <ul class="space-y-4 mb-8 flex-1">
              {plan.features.map(f => (
                <li class="flex items-start gap-3">
                  <svg class="flex-shrink-0 mt-0.5 text-[#8B1A2B]" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
                  <span class="text-sm text-white/70">{f}</span>
                </li>
              ))}
            </ul>

            <a href="#contacto" class={`w-full text-center ${plan.popular ? 'btn-primary' : 'btn-secondary'}`}>
              Elegir Plan
            </a>
          </div>
          
          {plan.popular && (
            <div class="absolute inset-0 bg-gradient-to-b from-[#8B1A2B]/5 to-transparent pointer-events-none"></div>
          )}
        </div>
      ))}
    </div>

    <!-- Extras Bento -->
    <div class="max-w-4xl mx-auto bento-card p-6 md:p-8 fade-up">
      <div class="flex flex-col md:flex-row items-center justify-between gap-6 mb-8">
        <div>
          <h3 class="text-lg font-bold text-white">Módulos Extra</h3>
          <p class="text-sm text-white/50">Servicios adicionales integrables a cualquier plan.</p>
        </div>
        <a href="#contacto" class="btn-secondary text-xs py-2">Consultar</a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {extras.map(e => (
          <div class="flex justify-between items-center p-3 bg-white/[0.02] border border-white/5 rounded-xl">
            <span class="text-sm text-white/70">{e.name}</span>
            <span class="text-xs font-bold text-white/90">{e.price}</span>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>
