---
const plans = [
  {
    name: "Landing Institucional",
    price: "$58.000",
    usd: "$60 USD",
    monthly: "$10.000 CLP/mes",
    popular: false,
    features: [
      "1 página corporativa",
      "Hosting + dominio (1 año)",
      "Optimización técnica SEO",
      "Imágenes alta resolución",
      "Soporte prioritario (30 días)",
    ],
  },
  {
    name: "Portal Corporativo",
    price: "$80.000",
    usd: "$83 USD",
    monthly: "$15.000 CLP/mes",
    popular: true,
    features: [
      "Arquitectura de 6 páginas",
      "Hosting + dominio (1 año)",
      "Google Analytics integrado",
      "Sección Noticias/Blog",
      "Soporte prioritario (30 días)",
    ],
  },
  {
    name: "Plataforma E-Commerce",
    price: "$150.000",
    usd: "$156 USD",
    monthly: "$20.000 CLP/mes",
    popular: false,
    features: [
      "Transacciones seguras",
      "Hosting + dominio (1 año)",
      "Panel de administración",
      "Webpay / Mercado Pago",
      "Hasta 50 productos",
    ],
  },
  {
    name: "E-Commerce + ERP",
    price: "$300.000",
    usd: "$312 USD",
    monthly: "$30.000 CLP/mes",
    popular: false,
    features: [
      "Suite E-commerce total",
      "Sistema de gestión interna",
      "Inventario centralizado",
      "Reportes ejecutivos",
      "Roles de acceso",
    ],
  },
];
---

<section id="planes" class="py-32 relative z-10 border-t border-white/5">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">
    
    <div class="mb-20 fade-up text-center">
      <div class="saas-badge mb-6 mx-auto">Transparencia Corporativa</div>
      <h2 class="text-4xl md:text-5xl font-bold tracking-tight text-white mb-4">
        Estructura de <span class="text-white/40">Inversión.</span>
      </h2>
      <p class="text-sm text-white/50 max-w-lg mx-auto font-light">Desarrollo llave en mano. Todos los despliegues incluyen hosting, dominio y certificado de seguridad por el primer año.</p>
    </div>

    <!-- Corporate Pricing Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6">
      {plans.map((plan, i) => (
        <div class={`bento-card flex flex-col relative fade-up ${plan.popular ? 'border-[#8B1A2B]/40 bg-black/60' : 'bg-black/20'}`} style={`transition-delay: ${i * 0.1}s`}>
          
          <div class="p-8 flex flex-col h-full relative z-10">
            {plan.popular && (
              <div class="absolute top-0 right-8 bg-[#8B1A2B] text-white text-[0.55rem] uppercase tracking-widest px-3 py-1 font-bold">
                Más Elegido
              </div>
            )}
            
            <h3 class="text-xl font-bold text-white mb-2 pt-2">{plan.name}</h3>
            
            <div class="mb-8 pb-8 border-b border-white/10">
              <div class="flex items-baseline gap-1 mb-1">
                <span class="text-4xl font-bold text-white tracking-tighter">{plan.price}</span>
              </div>
              <div class="text-[0.65rem] text-white/30 uppercase tracking-widest font-bold mb-3">Ref: {plan.usd}</div>
              <div class="text-[0.65rem] text-white/60 font-light">
                Mantenimiento anual: {plan.monthly}
              </div>
            </div>

            <ul class="space-y-4 mb-10 flex-1">
              {plan.features.map(f => (
                <li class="flex items-start gap-3">
                  <div class="w-1.5 h-1.5 rounded-full bg-[#8B1A2B] mt-1.5 flex-shrink-0"></div>
                  <span class="text-sm text-white/70 font-light">{f}</span>
                </li>
              ))}
            </ul>

            <a href="#contacto" class={`w-full text-center ${plan.popular ? 'btn-primary' : 'btn-secondary'} text-xs tracking-widest uppercase`}>
              Seleccionar Arquitectura
            </a>
          </div>
          
        </div>
      ))}
    </div>

  </div>
</section>
