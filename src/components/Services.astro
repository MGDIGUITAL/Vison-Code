---
---
<section id="servicios" class="py-24 relative z-10">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">
    
    <div class="mb-16 text-center fade-up">
      <div class="saas-badge mb-4 mx-auto">Soluciones Core</div>
      <h2 class="text-4xl md:text-5xl font-bold tracking-tight text-white mb-4">
        Infraestructura digital <br/><span class="text-white/40">para escalar.</span>
      </h2>
    </div>

    <!-- Bento Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 auto-rows-[280px]">
      
      <!-- Card 1 (Span 2) -->
      <article class="bento-card md:col-span-2 p-8 flex flex-col justify-between group fade-up">
        <div class="w-12 h-12 rounded-full bg-white/5 border border-white/10 flex items-center justify-center mb-4 group-hover:bg-[#8B1A2B]/20 group-hover:border-[#8B1A2B]/40 transition-colors">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
        </div>
        <div>
          <h3 class="text-2xl font-bold text-white mb-2">Desarrollo Web & Corporativo</h3>
          <p class="text-sm text-white/60 max-w-sm">Arquitectura sólida, carga instantánea y optimización SEO. Sitios construidos para generar confianza y conversión.</p>
        </div>
        <!-- UI Abstracta Fondo -->
        <div class="absolute right-8 top-8 w-40 h-32 bg-gradient-to-br from-white/5 to-transparent rounded-lg border border-white/10 opacity-30 group-hover:opacity-100 transition-opacity flex flex-col p-3 gap-2">
           <div class="w-full h-3 bg-white/10 rounded-sm"></div>
           <div class="w-3/4 h-3 bg-white/10 rounded-sm"></div>
           <div class="w-1/2 h-3 bg-[#8B1A2B]/50 rounded-sm mt-auto"></div>
        </div>
      </article>

      <!-- Card 2 (Span 1) -->
      <article class="bento-card md:col-span-1 p-8 flex flex-col justify-between group fade-up" style="transition-delay: 0.1s">
        <div class="w-12 h-12 rounded-full bg-white/5 border border-white/10 flex items-center justify-center mb-4 group-hover:bg-[#8B1A2B]/20 group-hover:border-[#8B1A2B]/40 transition-colors">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><path d="M3 6h18M16 10a4 4 0 01-8 0"/></svg>
        </div>
        <div>
          <h3 class="text-xl font-bold text-white mb-2">E-commerce</h3>
          <p class="text-sm text-white/60">Tiendas online de alto rendimiento con pasarelas integradas.</p>
        </div>
      </article>

      <!-- Card 3 (Span 1) -->
      <article class="bento-card md:col-span-1 p-8 flex flex-col justify-between group fade-up" style="transition-delay: 0.2s">
        <div class="w-12 h-12 rounded-full bg-white/5 border border-white/10 flex items-center justify-center mb-4 group-hover:bg-[#8B1A2B]/20 group-hover:border-[#8B1A2B]/40 transition-colors">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
        </div>
        <div>
          <h3 class="text-xl font-bold text-white mb-2">IA Aplicada</h3>
          <p class="text-sm text-white/60">Diseño asistido y optimización de contenido con inteligencia artificial.</p>
        </div>
      </article>

      <!-- Card 4 (Span 2) -->
      <article class="bento-card md:col-span-2 p-8 flex flex-col justify-between group fade-up" style="transition-delay: 0.3s">
        <div class="w-12 h-12 rounded-full bg-white/5 border border-white/10 flex items-center justify-center mb-4 group-hover:bg-[#8B1A2B]/20 group-hover:border-[#8B1A2B]/40 transition-colors">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 3v18M15 3v18M3 9h18M3 15h18"/></svg>
        </div>
        <div class="relative z-10">
          <h3 class="text-2xl font-bold text-white mb-2">Sistemas ERP & Automatización</h3>
          <p class="text-sm text-white/60 max-w-sm">Plataformas internas para gestión de inventario, ventas y procesos administrativos. Reducción de tareas manuales a cero.</p>
        </div>
        <!-- UI Abstracta Fondo -->
        <div class="absolute right-0 bottom-0 w-64 h-40 bg-gradient-to-tl from-[#8B1A2B]/10 to-transparent opacity-50 group-hover:opacity-100 transition-opacity rounded-tl-3xl border-t border-l border-white/5 flex items-end justify-between p-4 gap-2">
           <div class="w-full bg-white/10 rounded-t-sm" style="height: 30%"></div>
           <div class="w-full bg-[#8B1A2B]/40 rounded-t-sm" style="height: 80%"></div>
           <div class="w-full bg-white/20 rounded-t-sm" style="height: 50%"></div>
           <div class="w-full bg-white/10 rounded-t-sm" style="height: 60%"></div>
        </div>
      </article>

    </div>
  </div>
</section>
