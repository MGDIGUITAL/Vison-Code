---
const services = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><rect x="2" y="3" width="20" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M8 21h8M12 17v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
    title: "Landing Pages",
    desc: "Páginas de aterrizaje que convierten visitantes en clientes. Rápidas, responsive y diseñadas con IA.",
    tag: "Desde $58.000 CLP",
    num: "01",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5"/><path d="M12 3C12 3 9 7 9 12s3 9 3 9M12 3c0 0 3 4 3 9s-3 9-3 9M3 12h18" stroke="currentColor" stroke-width="1.5"/></svg>`,
    title: "Sitios Web Completos",
    desc: "Hasta 6 páginas internas con blog, Google Analytics, y todo lo que tu empresa necesita para destacar.",
    tag: "Desde $80.000 CLP",
    num: "02",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M3 6h18M16 10a4 4 0 01-8 0" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
    title: "Tienda Online",
    desc: "E-commerce con carrito de compras, Mercado Pago, Webpay y panel de administración. Hasta 50 productos.",
    tag: "Desde $150.000 CLP",
    num: "03",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><rect x="2" y="2" width="9" height="9" rx="1" stroke="currentColor" stroke-width="1.5"/><rect x="13" y="2" width="9" height="9" rx="1" stroke="currentColor" stroke-width="1.5"/><rect x="2" y="13" width="9" height="9" rx="1" stroke="currentColor" stroke-width="1.5"/><rect x="13" y="13" width="9" height="9" rx="1" stroke="currentColor" stroke-width="1.5"/></svg>`,
    title: "E-Commerce + ERP",
    desc: "Sistema completo con gestión de inventario, CRM, reportes, roles de usuario y capacitación incluida.",
    tag: "Desde $300.000 CLP",
    num: "04",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.5"/><path d="M21 21l-4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M11 8v3l2 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
    title: "SEO & Posicionamiento",
    desc: "Estrategia de posicionamiento para que tus clientes te encuentren primero en Google.",
    tag: "Desde $48.000 CLP",
    num: "05",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 2L4 6v6c0 5.25 3.4 10.15 8 12 4.6-1.85 8-6.75 8-12V6L12 2z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    title: "Mantenimiento Web",
    desc: "Soporte mensual con reuniones asincrónicas, actualizaciones de seguridad y mejoras continuas.",
    tag: "Desde $10.000/mes",
    num: "06",
  },
];
---

<section id="servicios" class="py-32 bg-[#0a0a0a] relative overflow-hidden">
  <!-- Dot grid background -->
  <div class="absolute inset-0 dot-grid opacity-100 pointer-events-none"></div>
  <!-- Glow decorativo -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] pointer-events-none" style="background: radial-gradient(ellipse, rgba(139,26,43,0.06) 0%, transparent 65%);"></div>

  <div class="max-w-7xl mx-auto px-6 lg:px-10 relative z-10">
    <!-- Section header -->
    <div class="mb-20 reveal">
      <div class="section-eyebrow">
        <span class="eyebrow-num">01</span>
        <span class="eyebrow-line"></span>
        <span class="eyebrow-label">Servicios</span>
      </div>
      <h2 class="font-display text-5xl md:text-6xl font-bold text-white leading-tight mb-5">
        Lo que <span class="text-brand-red">construimos</span>
      </h2>
      <p class="font-body text-white/50 text-lg max-w-lg leading-relaxed">
        Soluciones digitales completas para negocios que quieren crecer. Sin tecnicismos, con resultados.
      </p>
    </div>

    <!-- Services grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px bg-white/[0.04]">
      {services.map((s, i) => (
        <article class={`service-card glass-card p-8 group reveal reveal-delay-${(i % 4) + 1} relative`}>
          <!-- Card number -->
          <span class="absolute top-6 right-6 font-display text-6xl font-bold text-white/[0.035] leading-none select-none pointer-events-none">{s.num}</span>

          <!-- Icon wrapper -->
          <div class="service-icon-wrap mb-7">
            <div class="service-icon text-brand-red" set:html={s.icon} />
          </div>

          <h3 class="font-display text-xl font-bold text-white mb-3 group-hover:text-brand-red transition-colors duration-300">
            {s.title}
          </h3>
          <p class="font-body text-white/50 text-sm leading-relaxed mb-7">{s.desc}</p>
          <span class="inline-block font-body text-xs font-semibold text-brand-red border border-brand-red/25 px-3 py-1.5 tracking-widest uppercase">
            {s.tag}
          </span>

          <!-- Bottom animated line -->
          <div class="service-line"></div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .service-card {
    position: relative;
    overflow: hidden;
  }
  .service-icon-wrap {
    width: 52px;
    height: 52px;
    background: rgba(139,26,43,0.12);
    border: 1px solid rgba(139,26,43,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.3s, border-color 0.3s;
  }
  .service-card:hover .service-icon-wrap {
    background: rgba(139,26,43,0.2);
    border-color: rgba(139,26,43,0.5);
  }
  .service-line {
    position: absolute;
    bottom: 0; left: 0;
    width: 0; height: 2px;
    background: linear-gradient(90deg, #8B1A2B, #A52030);
    transition: width 0.5s cubic-bezier(0.16,1,0.3,1);
  }
  .service-card:hover .service-line { width: 100%; }
</style>
