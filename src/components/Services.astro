---
---
<section id="servicios" class="py-32 relative z-10">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">
    
    <div class="mb-20 text-center fade-up">
      <div class="saas-badge mb-6 mx-auto">Soluciones Core</div>
      <h2 class="text-4xl md:text-5xl font-bold tracking-tight text-white mb-6">
        Infraestructura digital <br/><span class="text-white/40">para escalar.</span>
      </h2>
    </div>

    <!-- Corporate Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 auto-rows-[280px]">
      
      <!-- Card 1 (Span 2) -->
      <article class="bento-card md:col-span-2 p-10 flex flex-col justify-between group fade-up relative overflow-hidden">
        <div class="relative z-10">
          <div class="w-12 h-12 border border-white/20 flex items-center justify-center mb-6 bg-black/50 backdrop-blur-md">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
          </div>
          <h3 class="text-2xl font-bold text-white mb-3">Desarrollo Corporativo</h3>
          <p class="text-sm text-white/60 max-w-md leading-relaxed">Arquitectura sólida, carga instantánea y optimización SEO. Portales construidos bajo los más altos estándares de seguridad y performance empresarial.</p>
        </div>
        <!-- Minimal Corporate Deco -->
        <div class="absolute right-0 bottom-0 w-1/2 h-1/2 border-t border-l border-white/5 bg-gradient-to-tl from-white/[0.03] to-transparent pointer-events-none"></div>
      </article>

      <!-- Card 2 (Span 1) -->
      <article class="bento-card md:col-span-1 p-10 flex flex-col justify-between group fade-up" style="transition-delay: 0.1s">
        <div>
          <div class="w-12 h-12 border border-white/20 flex items-center justify-center mb-6 bg-black/50 backdrop-blur-md">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><path d="M3 6h18M16 10a4 4 0 01-8 0"/></svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-3">E-Commerce B2B/B2C</h3>
          <p class="text-sm text-white/60 leading-relaxed">Tiendas online de alto rendimiento con pasarelas integradas e inventario sincronizado.</p>
        </div>
      </article>

      <!-- Card 3 (Span 1) -->
      <article class="bento-card md:col-span-1 p-10 flex flex-col justify-between group fade-up" style="transition-delay: 0.2s">
        <div>
          <div class="w-12 h-12 border border-white/20 flex items-center justify-center mb-6 bg-black/50 backdrop-blur-md">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-3">Auditoría IA</h3>
          <p class="text-sm text-white/60 leading-relaxed">Implementación de inteligencia artificial para la optimización de procesos internos.</p>
        </div>
      </article>

      <!-- Card 4 (Span 2) -->
      <article class="bento-card md:col-span-2 p-10 flex flex-col justify-between group fade-up relative overflow-hidden" style="transition-delay: 0.3s">
        <div class="relative z-10">
          <div class="w-12 h-12 border border-[#8B1A2B]/50 flex items-center justify-center mb-6 bg-[#8B1A2B]/10 backdrop-blur-md text-[#8B1A2B]">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 3v18M15 3v18M3 9h18M3 15h18"/></svg>
          </div>
          <h3 class="text-2xl font-bold text-white mb-3">Sistemas ERP & Automatización</h3>
          <p class="text-sm text-white/60 max-w-md leading-relaxed">Plataformas operativas para gestión de inventario, ventas y procesos administrativos. Centralización total de datos para la toma de decisiones gerenciales.</p>
        </div>
        <!-- Minimal Corporate Deco -->
        <div class="absolute right-0 top-0 w-1/3 h-full border-l border-[#8B1A2B]/20 bg-gradient-to-l from-[#8B1A2B]/10 to-transparent pointer-events-none"></div>
      </article>

    </div>
  </div>
</section>
