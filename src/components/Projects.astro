---
const projects = [
  {
    title: "Plataforma E-commerce Global",
    category: "Retail Tech",
    url: "#",
    status: "published",
    image: "/images/proyectos/ecommerce.png"
  },
  {
    title: "Portal Corporativo de Inversiones",
    category: "FinTech",
    url: "#",
    status: "updating",
    image: "/images/proyectos/web.png"
  },
  {
    title: "Sistema ERP para Logística",
    category: "Administración / SaaS",
    url: "#",
    status: "updating",
    image: "/images/proyectos/erp.png"
  },
  {
    title: "Arquitectura Web Institucional",
    category: "Corporate",
    url: "#",
    status: "published",
    image: "/images/proyectos/web.png"
  }
];
---

<section id="proyectos" class="py-40 relative z-10 overflow-hidden">
  <div class="max-w-[90rem] mx-auto px-6 lg:px-12">
    
    <div class="flex flex-col md:flex-row justify-between items-end gap-10 mb-28 fade-up">
      <div>
        <div class="saas-badge mb-6 tracking-[0.2em]">Portafolio Confidencial</div>
        <h2 class="text-5xl md:text-6xl lg:text-7xl font-bold tracking-tighter text-white leading-[1.1]">
          Casos de estudio <br/>
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-white/60 to-white/20">corporativos.</span>
        </h2>
      </div>
      <a href="#contacto" class="btn-secondary text-sm px-8 py-4 whitespace-nowrap hover:bg-white/5">
        Solicitar credenciales de acceso
      </a>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 md:gap-12">
      {projects.map((p, i) => (
        <article class="bento-card group flex flex-col fade-up overflow-hidden border-white/10 hover:border-[#8B1A2B]/30 hover:shadow-[0_0_50px_rgba(139,26,43,0.15)]" style={`transition-delay: ${i * 0.15}s`}>
          
          <!-- Image Corporate Style -->
          <div class="w-full aspect-[16/9] bg-[#030303] relative border-b border-white/10 overflow-hidden">
            <img src={p.image} alt={p.title} class="w-full h-full object-cover opacity-50 group-hover:opacity-90 group-hover:scale-105 transition-transform duration-700 ease-out" loading="lazy" />
            
            <div class="absolute inset-0 bg-gradient-to-t from-[var(--saas-bg)] via-black/40 to-transparent opacity-90 group-hover:opacity-40 transition-opacity duration-500"></div>
            
            <div class="absolute top-6 left-6 right-6 flex justify-between items-center z-10">
              <span class="saas-badge border border-white/20 bg-black/60 backdrop-blur-xl text-[0.65rem] tracking-[0.15em] px-4 py-1.5 rounded-sm shadow-xl">
                {p.category}
              </span>
              <span class={`w-2.5 h-2.5 rounded-full ${p.status === 'published' ? 'bg-[#8B1A2B] shadow-[0_0_15px_rgba(139,26,43,0.8)] animate-pulse' : 'bg-white/30'}`}></span>
            </div>
          </div>

          <!-- Content -->
          <div class="p-8 md:p-10 flex items-center justify-between bg-black/40">
            <div>
              <h3 class="text-2xl font-bold text-white mb-3 group-hover:text-[#8B1A2B] transition-colors duration-300 tracking-tight">{p.title}</h3>
              <p class="text-xs font-semibold text-white/50 uppercase tracking-[0.2em]">{p.status === 'published' ? 'Despliegue Activo' : 'Fase de Arquitectura'}</p>
            </div>
            {p.status === 'published' ? (
              <a href={p.url} class="w-14 h-14 rounded-lg bg-white/5 border border-white/10 flex items-center justify-center text-white/50 hover:bg-[#8B1A2B] hover:text-white hover:border-[#8B1A2B] hover:shadow-[0_0_20px_rgba(139,26,43,0.4)] transition-all duration-300">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
            ) : (
              <span class="w-14 h-14 rounded-lg border border-white/5 flex items-center justify-center text-white/20 bg-black/20">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
              </span>
            )}
          </div>

        </article>
      ))}
    </div>
  </div>
</section>
