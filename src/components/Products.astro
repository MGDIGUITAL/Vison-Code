---
const products = [
  {
    img: "/images/productos/lading-basica.png",
    name: "Landing Institucional",
    price: "$58.000 CLP",
    desc: "Presencia digital de alta conversión. Ideal para captar leads corporativos.",
    tags: ["Formulario", "Optimizada SEO"],
    popular: false,
  },
  {
    img: "/images/productos/lading-sitioweb.png",
    name: "Portal Corporativo",
    price: "$80.000 CLP",
    desc: "Arquitectura multi-página para empresas establecidas. Presencia integral y escalable.",
    tags: ["Multi-página", "Analytics"],
    popular: true,
  },
  {
    img: "/images/productos/lading-ecommerce.png",
    name: "Plataforma E-Commerce",
    price: "$150.000 CLP",
    desc: "Comercio electrónico transaccional seguro con pasarela de pago y sincronización de stock.",
    tags: ["Transaccional", "Inventario"],
    popular: false,
  },
  {
    img: "/images/productos/lading-ecommerce-erp.png",
    name: "E-Commerce + ERP",
    price: "$300.000 CLP",
    desc: "La suite definitiva. Tienda conectada a un sistema de gestión centralizado para ventas y clientes.",
    tags: ["Sistema Interno", "Reportes"],
    popular: false,
  },
];
---

<section id="productos" class="py-32 relative z-10">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">
    
    <div class="mb-20 fade-up">
      <div class="flex items-center gap-4 mb-4">
        <div class="h-px bg-white/20 w-12"></div>
        <div class="saas-badge border-none text-white/50 tracking-widest text-[0.65rem] px-0">Soluciones Empaquetadas</div>
      </div>
      <h2 class="text-4xl md:text-5xl font-bold tracking-tight text-white mb-4">
        Arquitectura lista <br/><span class="text-white/40">para despliegue.</span>
      </h2>
    </div>

    <!-- Corporate Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      {products.map((p, i) => (
        <article class="bento-card group flex flex-col sm:flex-row h-auto sm:h-[280px] fade-up overflow-hidden" style={`transition-delay: ${i * 0.1}s`}>
          
          <!-- Image Section -->
          <div class="w-full sm:w-[40%] h-48 sm:h-full bg-black relative border-r border-white/5">
            <img src={p.img} alt={p.name} class="w-full h-full object-cover opacity-60 group-hover:opacity-100 group-hover:scale-105 transition-all duration-700" loading="lazy" />
            
            {p.popular && (
              <div class="absolute top-0 right-0 z-10">
                <span class="bg-[#8B1A2B] text-white text-[0.55rem] font-bold uppercase tracking-widest px-3 py-1.5 shadow-lg">
                  Estándar Industria
                </span>
              </div>
            )}
          </div>

          <!-- Content Section -->
          <div class="w-full sm:w-[60%] p-8 flex flex-col justify-between relative z-10 bg-black/40">
            <div>
              <h3 class="text-xl font-bold text-white mb-1 group-hover:text-[#8B1A2B] transition-colors">{p.name}</h3>
              <div class="text-[#8B1A2B] font-bold tracking-tight text-lg mb-4">{p.price}</div>
              <p class="text-xs text-white/60 leading-relaxed font-light">
                {p.desc}
              </p>
            </div>
            
            <div class="flex items-center justify-between mt-6">
              <div class="flex gap-2">
                {p.tags.map(tag => (
                  <span class="text-[0.6rem] uppercase tracking-widest text-white/40">
                    {tag}
                  </span>
                ))}
              </div>
              <a href="#contacto" class="text-xs text-white hover:text-[#8B1A2B] transition-colors flex items-center gap-2">
                Cotizar <span class="font-serif">→</span>
              </a>
            </div>
          </div>
          
        </article>
      ))}
    </div>

  </div>
</section>
