---
const products = [
  {
    img: "/images/productos/lading-basica.png",
    name: "Landing Institucional",
    price: "$58.000 CLP",
    desc: "Presencia digital de alta conversión. Ideal para captar leads corporativos.",
    tags: ["Formulario", "Optimizada SEO"],
    popular: false,
  },
  {
    img: "/images/productos/lading-sitioweb.png",
    name: "Portal Corporativo",
    price: "$80.000 CLP",
    desc: "Arquitectura multi-página para empresas establecidas. Presencia integral y escalable.",
    tags: ["Multi-página", "Analytics"],
    popular: true,
  },
  {
    img: "/images/productos/lading-ecommerce.png",
    name: "Plataforma E-Commerce",
    price: "$150.000 CLP",
    desc: "Comercio electrónico transaccional seguro con pasarela de pago y sincronización de stock.",
    tags: ["Transaccional", "Inventario"],
    popular: false,
  },
  {
    img: "/images/productos/lading-ecommerce-erp.png",
    name: "E-Commerce + ERP",
    price: "$300.000 CLP",
    desc: "La suite definitiva. Tienda conectada a un sistema de gestión centralizado para ventas y clientes.",
    tags: ["Sistema Interno", "Reportes"],
    popular: false,
  },
];
---

<section id="productos" class="py-40 relative z-10 overflow-hidden">
  <div class="max-w-[90rem] mx-auto px-6 lg:px-12">
    
    <div class="mb-28 fade-up">
      <div class="flex items-center gap-4 mb-6">
        <div class="h-px bg-white/20 w-16"></div>
        <div class="saas-badge border-none text-white/50 tracking-[0.2em] text-[0.7rem] px-0">Soluciones Empaquetadas</div>
      </div>
      <h2 class="text-5xl md:text-6xl lg:text-7xl font-bold tracking-tighter text-white mb-6 leading-[1.1]">
        Arquitectura lista <br/>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-white/60 to-white/20">para despliegue.</span>
      </h2>
    </div>

    <!-- Corporate Grid -->
    <div class="grid grid-cols-1 xl:grid-cols-2 gap-8 md:gap-12">
      {products.map((p, i) => (
        <article class="bento-card group flex flex-col h-auto fade-up overflow-hidden hover:border-[#8B1A2B]/40 hover:shadow-[0_0_40px_rgba(139,26,43,0.15)] bg-black/20" style={`transition-delay: ${i * 0.15}s`}>
          
          <!-- Image Section -->
          <div class="w-full h-80 sm:h-[400px] bg-black/40 relative border-b border-white/10 overflow-hidden flex items-center justify-center p-6">
            <div class="absolute inset-0 bg-[#8B1A2B]/10 mix-blend-overlay z-10 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>
            <img src={p.img} alt={p.name} class="w-full h-full object-contain opacity-80 group-hover:opacity-100 group-hover:scale-105 transition-transform duration-700 ease-out drop-shadow-2xl" loading="lazy" />
            
            {p.popular && (
              <div class="absolute top-4 right-4 z-20">
                <span class="bg-[#8B1A2B] text-white text-[0.65rem] font-bold uppercase tracking-[0.15em] px-4 py-2 shadow-[0_0_20px_rgba(139,26,43,0.6)] rounded-sm">
                  Estándar Industria
                </span>
              </div>
            )}
          </div>

          <!-- Content Section -->
          <div class="w-full p-8 md:p-10 flex flex-col justify-between relative z-10 bg-black/40 backdrop-blur-sm grow">
            <div>
              <div class="flex justify-between items-start mb-4">
                <h3 class="text-2xl md:text-3xl font-bold text-white group-hover:text-[#8B1A2B] transition-colors duration-300 tracking-tight">{p.name}</h3>
              </div>
              <p class="text-sm md:text-base text-white/60 leading-relaxed font-light mb-6">
                {p.desc}
              </p>
            </div>
            
            <div class="flex flex-col xl:flex-row xl:items-center justify-between mt-auto pt-6 border-t border-white/10 gap-4 xl:gap-0">
              <div class="flex flex-wrap gap-2">
                {p.tags.map(tag => (
                  <span class="text-[0.65rem] uppercase tracking-[0.15em] text-white/40 bg-white/5 px-2 py-1 rounded-sm border border-white/5 group-hover:border-white/20 transition-colors">
                    {tag}
                  </span>
                ))}
              </div>
              <div class="flex items-center justify-between xl:justify-end gap-4 shrink-0 xl:ml-4">
                <a href="#contacto" class="text-sm text-white/70 hover:text-white transition-colors flex items-center font-medium shrink-0">
                  Cotizar
                </a>
                <a href={`https://wa.me/56929645522?text=Hola,%20me%20interesa%20comprar%20el%20servicio:%20${encodeURIComponent(p.name)}`} target="_blank" rel="noopener noreferrer" class="text-xs bg-[#8B1A2B] hover:bg-white hover:text-[#8B1A2B] text-white px-4 py-2 rounded-sm transition-colors flex items-center gap-2 font-bold uppercase tracking-[0.1em] shrink-0">
                  Comprar Ya <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
                </a>
              </div>
            </div>
          </div>
          
        </article>
      ))}
    </div>

  </div>
</section>
