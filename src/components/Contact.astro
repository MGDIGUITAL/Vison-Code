---
const whatsappNumber = "+56929645522";
const whatsappMsg = "Hola Vision Code, me gustaría conversar sobre un proyecto.";
const waLink = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(whatsappMsg)}`;
---

<section id="contacto" class="py-24 relative z-10">
  <div class="max-w-5xl mx-auto px-6 lg:px-10">
    
    <div class="bento-card p-8 md:p-12 fade-up relative overflow-hidden">
      <!-- Glow Decorativo -->
      <div class="absolute top-0 right-0 w-96 h-96 bg-[#8B1A2B]/10 blur-[100px] rounded-full pointer-events-none"></div>

      <div class="grid md:grid-cols-2 gap-12 relative z-10">
        
        <!-- Info -->
        <div>
          <div class="saas-badge mb-6">Contáctanos</div>
          <h2 class="text-3xl md:text-4xl font-bold text-white tracking-tight mb-4">
            ¿Listo para escalar <br/>tu negocio?
          </h2>
          <p class="text-sm text-white/60 mb-8 max-w-sm">
            Cuéntanos sobre tu proyecto. Analizaremos tus necesidades y te enviaremos una propuesta clara en menos de 24 horas.
          </p>

          <div class="space-y-4">
            <a href="mailto:Vision.code.vs@gmail.com" class="flex items-center gap-3 p-4 rounded-xl bg-white/[0.02] border border-white/5 hover:bg-white/[0.04] hover:border-white/10 transition-all group">
              <div class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center text-white/50 group-hover:text-white transition-colors">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
              </div>
              <div>
                <div class="text-[0.65rem] font-bold uppercase tracking-wider text-white/40 mb-1">Email Directo</div>
                <div class="text-sm text-white font-medium">Vision.code.vs@gmail.com</div>
              </div>
            </a>

            <a href={waLink} target="_blank" class="flex items-center gap-3 p-4 rounded-xl bg-white/[0.02] border border-white/5 hover:bg-white/[0.04] hover:border-white/10 transition-all group">
              <div class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center text-[#25D366] group-hover:bg-[#25D366]/10 transition-colors">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
              </div>
              <div>
                <div class="text-[0.65rem] font-bold uppercase tracking-wider text-white/40 mb-1">WhatsApp</div>
                <div class="text-sm text-white font-medium">+56 9 2964 5522</div>
              </div>
            </a>
          </div>
        </div>

        <!-- Formulario SaaS -->
        <div>
          <form class="flex flex-col gap-4">
            <div class="flex flex-col gap-1">
              <label for="name" class="text-xs font-semibold text-white/50 pl-1">Nombre</label>
              <input type="text" id="name" required class="w-full bg-white/[0.03] border border-white/10 rounded-xl px-4 py-3 text-sm text-white placeholder:text-white/20 focus:ring-2 focus:ring-[#8B1A2B]/50 focus:border-[#8B1A2B] outline-none transition-all" placeholder="Tu nombre completo" />
            </div>
            
            <div class="flex flex-col gap-1">
              <label for="email" class="text-xs font-semibold text-white/50 pl-1">Email</label>
              <input type="email" id="email" required class="w-full bg-white/[0.03] border border-white/10 rounded-xl px-4 py-3 text-sm text-white placeholder:text-white/20 focus:ring-2 focus:ring-[#8B1A2B]/50 focus:border-[#8B1A2B] outline-none transition-all" placeholder="tucorreo@empresa.com" />
            </div>

            <div class="flex flex-col gap-1">
              <label for="message" class="text-xs font-semibold text-white/50 pl-1">Proyecto</label>
              <textarea id="message" rows="4" required class="w-full bg-white/[0.03] border border-white/10 rounded-xl px-4 py-3 text-sm text-white placeholder:text-white/20 focus:ring-2 focus:ring-[#8B1A2B]/50 focus:border-[#8B1A2B] outline-none transition-all resize-none" placeholder="Cuéntanos brevemente sobre lo que necesitas..."></textarea>
            </div>

            <button type="submit" class="btn-primary w-full mt-2 py-3.5">
              Enviar solicitud
            </button>
          </form>
        </div>

      </div>
    </div>
    
  </div>
</section>
