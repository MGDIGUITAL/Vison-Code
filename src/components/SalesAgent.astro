---
// Vision Code Ventas — Agente de ventas VisionCode
---

<div id="vc-agent">
  <button id="vc-bubble" aria-label="Hablar con Vision Code Ventas">
    <span id="vc-dot"></span>
    <svg id="ico-chat" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
    </svg>
    <svg id="ico-x" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round">
      <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
    </svg>
  </button>

  <div id="vc-panel">
    <div id="vc-header">
      <div id="vc-avatar">V</div>
      <div id="vc-header-info">
        <div id="vc-name">Vision Code Ventas</div>
        <div id="vc-status"><span class="dot-green"></span>Agente VisionCode · En línea</div>
      </div>
      <button id="vc-close">×</button>
    </div>
    <div id="vc-messages"></div>
    <div id="vc-input-row">
      <input id="vc-input" type="text" placeholder="Escribe aquí..." autocomplete="off"/>
      <button id="vc-send">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
        </svg>
      </button>
    </div>
  </div>
</div>

<style>
  #vc-agent { position: fixed; bottom: 24px; right: 24px; z-index: 9999; font-family: 'Inter', sans-serif; }

  #vc-bubble {
    width: 58px; height: 58px; border-radius: 50%;
    background: #8B1A2B; border: none; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 4px 20px rgba(139,26,43,0.45);
    position: relative;
  }
  #vc-bubble:hover { transform: scale(1.08); box-shadow: 0 6px 28px rgba(139,26,43,0.55); }
  #ico-x { display: none; position: absolute; }
  #vc-dot {
    position: absolute; top: 10px; right: 10px;
    width: 11px; height: 11px; background: #25D366;
    border-radius: 50%; border: 2px solid #030303;
  }

  #vc-panel {
    position: absolute; bottom: 70px; right: 0;
    width: 330px; background: #111;
    border: 0.5px solid #2a2a2a; border-radius: 16px;
    overflow: hidden; display: none; flex-direction: column;
    box-shadow: 0 8px 40px rgba(0,0,0,0.6);
  }
  #vc-panel.open { display: flex; }

  #vc-header {
    background: #0a0a0a; padding: 14px 16px;
    display: flex; align-items: center; gap: 10px;
    border-bottom: 0.5px solid #1f1f1f;
  }
  #vc-avatar {
    width: 36px; height: 36px; border-radius: 50%;
    background: #8B1A2B; display: flex; align-items: center;
    justify-content: center; font-size: 15px; font-weight: 700; color: #fff; flex-shrink: 0;
  }
  #vc-header-info { flex: 1; }
  #vc-name { font-size: 14px; font-weight: 600; color: #fff; }
  #vc-status { font-size: 10.5px; color: #aaa; display: flex; align-items: center; gap: 4px; margin-top: 1px; }
  .dot-green { width: 6px; height: 6px; background: #25D366; border-radius: 50%; display: inline-block; }
  #vc-close { background: none; border: none; color: #555; cursor: pointer; font-size: 22px; padding: 0; line-height: 1; }
  #vc-close:hover { color: #fff; }

  #vc-messages {
    height: 320px; overflow-y: auto;
    padding: 14px 12px; display: flex;
    flex-direction: column; gap: 10px; background: #0d0d0d;
  }
  #vc-messages::-webkit-scrollbar { width: 3px; }
  #vc-messages::-webkit-scrollbar-thumb { background: #2a2a2a; border-radius: 4px; }

  .msg {
    max-width: 88%; padding: 10px 14px;
    font-size: 13px; line-height: 1.6; white-space: pre-line;
  }
  .msg.bot {
    background: #1a1a1a; border: 0.5px solid #2a2a2a;
    color: #e5e5e5; align-self: flex-start;
    border-radius: 4px 14px 14px 14px;
  }
  .msg.user {
    background: #8B1A2B; color: #fff;
    align-self: flex-end; font-weight: 500;
    border-radius: 14px 4px 14px 14px;
  }
  .msg.typing { color: #555; font-style: italic; font-size: 12px; }

  /* Opciones con separador "/" */
  .opts-wrap {
    display: flex; flex-direction: column;
    gap: 5px; padding: 4px 12px 12px;
  }
  .opts-sep {
    display: flex; align-items: center;
    gap: 8px;
  }
  .opts-sep-line {
    color: rgba(139,26,43,0.4); font-size: 13px; font-weight: 300;
    user-select: none; padding: 0 2px;
  }
  .opt {
    flex: 1; font-size: 12.5px; padding: 9px 12px;
    border-radius: 6px;
    border: 1px solid rgba(139,26,43,0.35);
    border-left: 3px solid #8B1A2B;
    color: #e0b0b8;
    background: linear-gradient(90deg, rgba(139,26,43,0.12) 0%, rgba(26,10,12,0.6) 100%);
    cursor: pointer; transition: all 0.18s ease;
    text-align: left; font-weight: 500;
  }
  .opt:hover {
    background: linear-gradient(90deg, rgba(139,26,43,0.5) 0%, rgba(139,26,43,0.2) 100%);
    border-left-color: #c0293f; border-color: rgba(139,26,43,0.7);
    color: #fff; transform: translateX(3px);
  }

  /* Tarjeta de servicio seleccionado */
  .service-card {
    background: linear-gradient(135deg, rgba(139,26,43,0.15), rgba(10,5,6,0.8));
    border: 1px solid rgba(139,26,43,0.4);
    border-left: 3px solid #8B1A2B;
    border-radius: 8px; padding: 12px 14px;
    margin: 0 12px 10px; font-size: 12px;
    color: #e0b0b8; line-height: 1.7;
  }
  .service-card strong { color: #fff; display: block; margin-bottom: 4px; font-size: 13px; }

  .wa-btn {
    display: flex; align-items: center; justify-content: center; gap: 8px;
    margin: 4px 12px 12px; padding: 11px 16px;
    background: #25D366; color: #fff; border-radius: 8px;
    font-size: 13px; font-weight: 700; cursor: pointer;
    border: none; text-decoration: none; letter-spacing: 0.02em;
    transition: background 0.15s;
  }
  .wa-btn:hover { background: #1ebe5d; }

  #vc-input-row {
    display: none; gap: 8px; padding: 10px;
    border-top: 0.5px solid #1f1f1f; background: #111;
  }
  #vc-input-row.visible { display: flex; }
  #vc-input {
    flex: 1; font-size: 13px; padding: 9px 12px;
    background: #1a1a1a; border: 0.5px solid #2a2a2a;
    color: #fff; border-radius: 8px; font-family: 'Inter', sans-serif;
  }
  #vc-input::placeholder { color: #555; }
  #vc-input:focus { outline: none; border-color: #8B1A2B; }
  #vc-send {
    width: 36px; height: 36px; background: #8B1A2B;
    border: none; border-radius: 8px; cursor: pointer;
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  }
  #vc-send:hover { background: #a01e30; }
</style>

<script>
const WA_NUM = '56929645522';

// Estado del cliente
let clientName = '';
let clientEmail = '';
let clientPhone = '';
let clientService = '';
let step = 'nombre'; // nombre → correo → telefono → servicio → cierre

const SERVICIOS = [
  { label: 'Landing Institucional', precio: '$58.000 CLP', mant: '$10.000/mes' },
  { label: 'Portal Corporativo',    precio: '$80.000 CLP', mant: '$15.000/mes' },
  { label: 'Plataforma E-Commerce', precio: '$150.000 CLP', mant: '$20.000/mes' },
  { label: 'E-Commerce + ERP',      precio: '$300.000 CLP', mant: '$30.000/mes' },
];

// DOM
const bubble   = document.getElementById('vc-bubble');
const panel    = document.getElementById('vc-panel');
const closeBtn = document.getElementById('vc-close');
const msgsEl   = document.getElementById('vc-messages');
const inputEl  = document.getElementById('vc-input');
const sendBtn  = document.getElementById('vc-send');
const inputRow = document.getElementById('vc-input-row');
const icoChat  = document.getElementById('ico-chat');
const icoX     = document.getElementById('ico-x');
let started = false;

// ── Utilidades ───────────────────────────────────────────
function scroll() { msgsEl.scrollTop = msgsEl.scrollHeight; }

function addMsg(text, cls) {
  const d = document.createElement('div');
  d.className = 'msg ' + cls;
  d.textContent = text;
  msgsEl.appendChild(d);
  scroll();
  return d;
}

function showInput(visible, placeholder = 'Escribe aquí...') {
  if (visible) {
    inputRow.classList.add('visible');
    inputEl.placeholder = placeholder;
    inputEl.disabled = false;
    setTimeout(() => inputEl.focus(), 50);
  } else {
    inputRow.classList.remove('visible');
    inputEl.disabled = true;
    inputEl.value = '';
  }
}

function clearOpts() {
  document.querySelectorAll('.opts-wrap').forEach(o => o.remove());
}

// Renderiza opciones en columna con separador "/" entre cada una
function addOpts(opts, cb) {
  clearOpts();
  const wrap = document.createElement('div');
  wrap.className = 'opts-wrap';

  opts.forEach((o, i) => {
    const row = document.createElement('div');
    row.className = 'opts-sep';

    const sep = document.createElement('span');
    sep.className = 'opts-sep-line';
    sep.textContent = '/';

    const btn = document.createElement('button');
    btn.className = 'opt';
    btn.textContent = o.label || o;
    btn.onclick = () => { clearOpts(); cb(o); };

    row.appendChild(sep);
    row.appendChild(btn);
    wrap.appendChild(row);
  });

  msgsEl.appendChild(wrap);
  scroll();
}

function addServiceCard(s) {
  const card = document.createElement('div');
  card.className = 'service-card';
  card.innerHTML = `<strong>${s.label}</strong>Precio: ${s.precio} &nbsp;·&nbsp; Mantenimiento: ${s.mant}`;
  msgsEl.appendChild(card);
  scroll();
}

function addWAButton() {
  const msg = `¡Hola equipo VisionCode! 👋

Me gustaría gestionar la compra de un servicio. Aquí van mis datos:

👤 Nombre: ${clientName}
📧 Correo: ${clientEmail}
📱 Teléfono: ${clientPhone}
🛒 Servicio de interés: ${clientService}

Quedo atento/a a sus indicaciones para proceder. ¡Muchas gracias!`;

  const a = document.createElement('a');
  a.className = 'wa-btn';
  a.href = `https://wa.me/${WA_NUM}?text=${encodeURIComponent(msg)}`;
  a.target = '_blank';
  a.innerHTML = `<svg width="16" height="16" viewBox="0 0 24 24" fill="white"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.104.549 4.078 1.504 5.798L.057 23.428c-.083.334.216.633.55.55l5.63-1.447A11.951 11.951 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.807 9.807 0 01-5.003-1.37l-.358-.214-3.724.956.989-3.607-.235-.372A9.816 9.816 0 012.182 12C2.182 6.57 6.57 2.182 12 2.182S21.818 6.57 21.818 12 17.43 21.818 12 21.818z"/></svg>Gestionar mi compra por WhatsApp`;
  msgsEl.appendChild(a);
  scroll();
}

function delay(ms) { return new Promise(r => setTimeout(r, ms)); }

async function botSay(text, tipo = 'text', extra = null) {
  showInput(false);
  const t = addMsg('Vision Code Ventas está escribiendo...', 'bot typing');
  await delay(900);
  t.remove();
  addMsg(text, 'bot');

  if (tipo === 'input') {
    showInput(true, extra);
  } else if (tipo === 'opciones') {
    addOpts(extra, handleServiceSelect);
  } else if (tipo === 'cierre') {
    addServiceCard(extra);
    await delay(400);
    addWAButton();
  }
}

// ── Flujo principal ──────────────────────────────────────
async function start() {
  step = 'nombre';
  await botSay(
    '¡Hola! Soy Vision Code Ventas, tu agente de ventas de VisionCode 👋\n\n¿Con quién tengo el gusto de hablar? (nombre o empresa)',
    'input', 'Tu nombre o empresa...'
  );
}

async function handleInput(val) {
  addMsg(val, 'user');
  showInput(false);
  await delay(350);

  if (step === 'nombre') {
    clientName = val.trim();
    step = 'correo';
    await botSay(
      `Mucho gusto, ${clientName}! 😊\n\n¿Cuál es tu correo electrónico de contacto?`,
      'input', 'correo@empresa.com'
    );

  } else if (step === 'correo') {
    clientEmail = val.trim();
    step = 'telefono';
    await botSay(
      `Perfecto. ¿Y un número de teléfono donde podamos contactarte?`,
      'input', '+56 9 XXXX XXXX'
    );

  } else if (step === 'telefono') {
    clientPhone = val.trim();
    step = 'servicio';
    await botSay(
      `¡Excelente, ${clientName}! Ya tengo tus datos.\n\nSelecciona el servicio que más se ajusta a tu proyecto 👇`,
      'opciones', SERVICIOS
    );
  }
}

async function handleServiceSelect(servicio) {
  clientService = servicio.label;
  addMsg(servicio.label, 'user');
  step = 'cierre';
  await delay(350);
  await botSay(
    `¡Muy buena elección, ${clientName}! 🙌\n\nAquí tienes el detalle del servicio seleccionado. Al hacer clic en el botón, nuestro equipo recibirá toda tu información y te contactará a la brevedad para gestionar tu compra.`,
    'cierre', servicio
  );
}

// ── Eventos ──────────────────────────────────────────────
bubble.addEventListener('click', () => {
  const open = panel.classList.toggle('open');
  icoChat.style.display = open ? 'none' : 'block';
  icoX.style.display = open ? 'block' : 'none';
  if (open && !started) { started = true; start(); }
});

closeBtn.addEventListener('click', () => {
  panel.classList.remove('open');
  icoChat.style.display = 'block';
  icoX.style.display = 'none';
});

function doSend() {
  const val = inputEl.value.trim();
  if (val && !inputEl.disabled) handleInput(val);
}

sendBtn.addEventListener('click', doSend);
inputEl.addEventListener('keydown', e => { if (e.key === 'Enter') doSend(); });
</script>
