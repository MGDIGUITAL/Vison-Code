---
export interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "Vision Code — Consultora de Ingeniería y Desarrollo",
  description = "Soluciones tecnológicas corporativas, sistemas de gestión y plataformas e-commerce de alto rendimiento."
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Vision Code" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="theme-color" content="#030303" />
    <link rel="icon" type="image/png" href="/images/logo.png" />
    <title>{title}</title>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <!-- Global Styles -->
    <style is:global>
      :root {
        --saas-bg: #030303;
        --saas-surface: rgba(255, 255, 255, 0.02);
        --saas-border: rgba(255, 255, 255, 0.08);
        --saas-border-hover: rgba(255, 255, 255, 0.2);
        --saas-brand: #8B1A2B;
      }

      *, *::before, *::after { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        margin: 0;
        background-color: var(--saas-bg);
        color: #FFFFFF;
        font-family: 'Inter', system-ui, sans-serif;
        -webkit-font-smoothing: antialiased;
        overflow-x: hidden;
      }
      
      /* Fondo IA Corporativo */
      .bg-ai-corporate {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background-image: url('/images/bg-corporate.png');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        opacity: 0.25;
        z-index: -1;
        pointer-events: none;
      }

      ::selection { background: var(--saas-brand); color: #fff; }
      ::-webkit-scrollbar { width: 6px; }
      ::-webkit-scrollbar-track { background: var(--saas-bg); }
      ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.15); }
      ::-webkit-scrollbar-thumb:hover { background: rgba(255,255,255,0.3); }

      /* ── Corporate Cards ── */
      .bento-card {
        background: rgba(0, 0, 0, 0.4);
        border: 1px solid var(--saas-border);
        border-radius: 0.75rem; /* rounded-xl (más afilado y serio) */
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        transition: all 0.4s cubic-bezier(0.22, 1, 0.36, 1);
        position: relative;
        overflow: hidden;
        z-index: 10;
      }
      .bento-card:hover {
        border-color: var(--saas-border-hover);
        background: rgba(10, 10, 10, 0.6);
      }
      
      /* Luz sutil superior */
      .bento-card::after {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.15), transparent);
        opacity: 0;
        transition: opacity 0.4s ease;
      }
      .bento-card:hover::after { opacity: 1; }

      /* ── Badges y Botones Corporativos ── */
      .saas-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
        padding: 0.375rem 0.75rem;
        background: transparent;
        border: 1px solid rgba(255,255,255,0.2);
        border-radius: 0.25rem;
        font-size: 0.7rem;
        font-weight: 600;
        color: rgba(255,255,255,0.7);
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }
      
      .btn-primary {
        display: inline-flex;
        justify-content: center;
        align-items: center;
        gap: 0.5rem;
        background: var(--saas-brand);
        color: white;
        font-weight: 600;
        font-size: 0.875rem;
        padding: 0.75rem 2rem;
        border-radius: 0.25rem;
        transition: all 0.3s ease;
        text-decoration: none;
      }
      .btn-primary:hover {
        background: #a81c33;
      }
      
      .btn-secondary {
        display: inline-flex;
        justify-content: center;
        align-items: center;
        gap: 0.5rem;
        background: rgba(255,255,255,0.05);
        color: white;
        font-weight: 600;
        font-size: 0.875rem;
        padding: 0.75rem 2rem;
        border-radius: 0.25rem;
        border: 1px solid rgba(255,255,255,0.15);
        transition: all 0.3s ease;
        text-decoration: none;
      }
      .btn-secondary:hover {
        background: rgba(255,255,255,0.1);
        border-color: rgba(255,255,255,0.3);
      }

      /* ── Reveal Animations ── */
      .fade-up {
        opacity: 0;
        transform: translateY(20px);
        transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
      }
      .fade-up.in-view { opacity: 1; transform: translateY(0); }
      
      @media (prefers-reduced-motion: reduce) {
        *, *::before, *::after {
          animation-duration: 0.01ms !important;
          animation-iteration-count: 1 !important;
          transition-duration: 0.01ms !important;
          scroll-behavior: auto !important;
        }
      }
    </style>
  </head>
  <body>
    <div class="bg-ai-corporate"></div>
    <slot />
    
    <script>
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('in-view');
          }
        });
      }, { threshold: 0.1 });

      document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));
    </script>
  </body>
</html>
