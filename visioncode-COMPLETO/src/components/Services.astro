---
const services = [
  {
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><rect x="2" y="4" width="24" height="16" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M9 24h10M14 20v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
    title: "Landing Pages",
    desc: "Páginas de aterrizaje que convierten visitantes en clientes. Rápidas, responsive y diseñadas con IA.",
    tag: "Desde $58.000 CLP",
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><circle cx="14" cy="14" r="11" stroke="currentColor" stroke-width="1.5"/><path d="M14 3C14 3 10 8 10 14s4 11 4 11M14 3c0 0 4 5 4 11s-4 11-4 11M3 14h22" stroke="currentColor" stroke-width="1.5"/></svg>`,
    title: "Sitios Web Completos",
    desc: "Hasta 6 páginas internas con blog, Google Analytics, y todo lo que tu empresa necesita para destacar.",
    tag: "Desde $80.000 CLP",
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M4 6h20M4 12h20M4 18h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="22" cy="20" r="4" stroke="currentColor" stroke-width="1.5"/><path d="M20 20l1.5 1.5L24 18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
    title: "Tienda Online",
    desc: "E-commerce con carrito de compras, Mercado Pago, Webpay y panel de administración. Hasta 50 productos.",
    tag: "Desde $150.000 CLP",
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><rect x="3" y="3" width="10" height="10" rx="1" stroke="currentColor" stroke-width="1.5"/><rect x="15" y="3" width="10" height="10" rx="1" stroke="currentColor" stroke-width="1.5"/><rect x="3" y="15" width="10" height="10" rx="1" stroke="currentColor" stroke-width="1.5"/><rect x="15" y="15" width="10" height="10" rx="1" stroke="currentColor" stroke-width="1.5"/></svg>`,
    title: "E-Commerce + ERP",
    desc: "Sistema completo con gestión de inventario, CRM, reportes, roles de usuario y capacitación incluida.",
    tag: "Desde $300.000 CLP",
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M14 4v4M14 20v4M4 14h4M20 14h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="14" cy="14" r="6" stroke="currentColor" stroke-width="1.5"/><circle cx="14" cy="14" r="2" fill="currentColor"/></svg>`,
    title: "SEO & Posicionamiento",
    desc: "Estrategia de posicionamiento para que tus clientes te encuentren primero en Google.",
    tag: "Desde $48.000 CLP",
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M14 2L4 7v7c0 5.5 4.3 10.7 10 12 5.7-1.3 10-6.5 10-12V7L14 2z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M9 14l3 3 7-7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    title: "Mantenimiento Web",
    desc: "Soporte mensual con reuniones asincrónicas, actualizaciones de seguridad y mejoras continuas.",
    tag: "Desde $10.000 CLP/mes",
  },
];
---

<section id="servicios" class="py-28 bg-brand-black relative overflow-hidden">
  <!-- Background texture -->
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: repeating-linear-gradient(0deg, transparent, transparent 40px, rgba(255,255,255,0.5) 40px, rgba(255,255,255,0.5) 41px), repeating-linear-gradient(90deg, transparent, transparent 40px, rgba(255,255,255,0.5) 40px, rgba(255,255,255,0.5) 41px);"></div>

  <div class="max-w-7xl mx-auto px-6 lg:px-10 relative z-10">
    <!-- Section header -->
    <div class="mb-16 reveal">
      <span class="accent-line"></span>
      <h2 class="font-display text-4xl md:text-5xl font-bold text-white mb-4">
        Lo que <span class="text-brand-red">construimos</span>
      </h2>
      <p class="font-body text-white/60 text-lg max-w-xl">
        Soluciones digitales completas para negocios que quieren crecer. Sin tecnicismos, con resultados.
      </p>
    </div>

    <!-- Services grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px bg-brand-gray/20">
      {services.map((s, i) => (
        <article class={`service-card bg-brand-dark p-8 group reveal reveal-delay-${(i % 4) + 1}`}>
          <div class="service-icon text-brand-red mb-6" set:html={s.icon} />
          <h3 class="font-display text-xl font-semibold text-white mb-3 group-hover:text-brand-red transition-colors">
            {s.title}
          </h3>
          <p class="font-body text-white/55 text-sm leading-relaxed mb-6">{s.desc}</p>
          <span class="inline-block font-body text-xs font-semibold text-brand-red border border-brand-red/30 px-3 py-1 tracking-wide uppercase">
            {s.tag}
          </span>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .service-card {
    border: 1px solid rgba(255,255,255,0.05);
    transition: border-color 0.3s, background 0.3s;
    position: relative;
    overflow: hidden;
  }
  .service-card::before {
    content: '';
    position: absolute;
    bottom: 0; left: 0;
    width: 0; height: 2px;
    background: #8B1A2B;
    transition: width 0.4s ease;
  }
  .service-card:hover::before { width: 100%; }
  .service-card:hover {
    background: #1a1a1a;
    border-color: rgba(139, 26, 43, 0.3);
  }
</style>
